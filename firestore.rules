rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /roomAssignments/{document} {
      allow read, write: if true;
    }

    match /defaultStaffSettings/{document} {
      allow read, write: if true;
    }

    match /dailySchedules/{date} {
      allow read, write: if true;
    }
  }
}
